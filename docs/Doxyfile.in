PROJECT_NAME           = "CONFIGURED"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@CMAKE_BINARY_DIR@/docs"
CREATE_SUBDIRS         = NO

INPUT                  = "@CMAKE_SOURCE_DIR@/src" "@CMAKE_SOURCE_DIR@/include" "@CMAKE_SOURCE_DIR@/docs/mainpage.dox" "@CMAKE_SOURCE_DIR@/docs/tests.dox"

RECURSIVE              = YES

FILE_PATTERNS          = *.h *.hpp *.c *.cc *.cpp *.dox
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO

QUIET                  = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = NO

HAVE_DOT               = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
CLASS_DIAGRAMS         = YES

FULL_PATH_NAMES        = NO
INLINE_SOURCES         = NO
SOURCE_BROWSER         = YES
STRIP_CODE_COMMENTS    = NO