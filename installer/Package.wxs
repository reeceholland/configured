<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
	<Package Name="Configured" Manufacturer="Configured" Version="0.5.0" UpgradeCode="c2fcce7b-1579-4765-b804-5905c22e1e3e">
		<MediaTemplate />
		<StandardDirectory Id="ProgramFiles64Folder">
			<Directory Id="INSTALLFOLDER" Name="Configured" />
		</StandardDirectory>
		<StandardDirectory Id="ProgramMenuFolder">
			<Directory Id="ApplicationProgramsFolder" Name="Configured" />
		</StandardDirectory>
		<StandardDirectory Id="DesktopFolder">
			<Component Id="DesktopShortcut" Guid="*">
				<Shortcut Id="DesktopShortcut" Name="Configured" Target="[INSTALLFOLDER]Configured.exe" />
				<RegistryValue Root="HKCU" Key="Software\Configured" Name="desktop" Type="integer" Value="1" KeyPath="yes" />
			</Component>
		</StandardDirectory>
		<Feature Id="MainFeature" Title="Configured" Level="1">
			<ComponentGroupRef Id="ProductComponents" />
			<ComponentRef Id="StartMenuShortcut" />
			<ComponentRef Id="DesktopShortcut" />
		</Feature>
	</Package>
	<Fragment>
		<DirectoryRef Id="ApplicationProgramsFolder">
			<Component Id="StartMenuShortcut" Guid="*">
				<Shortcut Id="StartMenuShortcut" Name="Configured" Target="[INSTALLFOLDER]Configured.exe" />
				<RemoveFolder Id="RemoveProgramMenuFolder" On="uninstall" />
				<RegistryValue Root="HKCU" Key="Software\Configured" Name="installed" Type="integer" Value="1" KeyPath="yes" />
			</Component>
		</DirectoryRef>
	</Fragment>
</Wix>
